# vi: ft=systemd
# /etc/systemd/network/30-dn42-xkrme-tyo.netdev

[NetDev]
Name=wg1733xkrmetyo
Kind=wireguard
Description=WireGuard tunnel to AS4242421733 xkrme TYO

[WireGuard]
ListenPort=24241
PrivateKeyFile=/etc/systemd/network/dn42.wgkey

[WireGuardPeer]
PublicKey=4KZ0OVselhQFSfTEhzbYgxRuL9oG1sn3xsle6TVSfnE=
Endpoint=tyo1.entry.dn42.hk:20893
AllowedIPs=10.0.0.0/8
AllowedIPs=172.20.0.0/14
AllowedIPs=172.31.0.0/16
AllowedIPs=fd00::/8
AllowedIPs=fe80::/64
