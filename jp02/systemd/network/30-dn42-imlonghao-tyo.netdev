# vi: ft=systemd
# /etc/systemd/network/30-dn42-imlonghao-tyo.netdev

[NetDev]
Name=wg1888imlonghaotyo
Kind=wireguard
Description=WireGuard tunnel to AS4242421888 imlonghao tyo

[WireGuard]
ListenPort=24288
PrivateKeyFile=/etc/systemd/network/dn42.wgkey

[WireGuardPeer]
PublicKey=HND/VBClYdfCqAKGFmapwqOxg/KluPcv2u30rjD8+gk=
Endpoint=jp1.dn42.ni.sb:20893
AllowedIPs=10.0.0.0/8
AllowedIPs=172.20.0.0/14
AllowedIPs=172.31.0.0/16
AllowedIPs=fd00::/8
AllowedIPs=fe80::/64
