# vi: ft=systemd
# /etc/systemd/network/30-dn42-dststr-sg.network

[Match]
Name=wg1771dststrsg

[Link]
RequiredForOnline=degraded:routable
RequiredFamilyForOnline=ipv6
Group=4242

[Network]
Description=WireGuard tunnel to AS4242421771 Duststars Singapore
DHCP=no
IPv6AcceptRA=false
IPv4ReversePathFilter=no
IPv4Forwarding=yes
IPv6Forwarding=yes
KeepConfiguration=yes

[Address]
Address=fe80::893/64
Peer=fe80::35f6:d4ac:169:cdfc/64
