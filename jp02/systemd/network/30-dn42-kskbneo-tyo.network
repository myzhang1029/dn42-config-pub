# vi: ft=systemd
# /etc/systemd/network/30-dn42-kskbneo-tyo.network

[Match]
Name=wg1111kskbneoty

[Link]
RequiredForOnline=degraded:routable
RequiredFamilyForOnline=ipv6
Group=4242

[Network]
Description=WireGuard tunnel to AS4201271111 Kusakabe Neo Tokyo
DHCP=no
IPv6AcceptRA=false
IPv4ReversePathFilter=no
IPv4Forwarding=yes
IPv6Forwarding=yes
KeepConfiguration=yes

[Address]
Address=fe80::893/64
Peer=fe80::1111/64
