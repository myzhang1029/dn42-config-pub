# vi: ft=systemd
# /etc/systemd/network/30-dn42-iyoroy-lax.network

[Match]
Name=wg2024iyoroylax

[Link]
RequiredForOnline=degraded:routable
RequiredFamilyForOnline=ipv6
Group=4242

[Network]
Description=WireGuard tunnel to AS4242422024 iYoRoy Los Angeles
DHCP=no
IPv6AcceptRA=false
IPv4ReversePathFilter=no
IPv4Forwarding=yes
IPv6Forwarding=yes
KeepConfiguration=yes

[Address]
Address=fe80::893/64
Peer=fe80::2024/64
