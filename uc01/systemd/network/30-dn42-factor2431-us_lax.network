# vi: ft=systemd
# /etc/systemd/network/30-dn42-factor2431-us_lax.network

[Match]
Name=wg1534factorlax

[Link]
RequiredForOnline=degraded:routable
RequiredFamilyForOnline=ipv6
Group=4242

[Network]
Description=WireGuard tunnel to AS4242421534 factor2431 us_lax
DHCP=no
IPv6AcceptRA=false
IPv4ReversePathFilter=no
IPv4Forwarding=yes
IPv6Forwarding=yes
KeepConfiguration=yes

[Address]
Address=fe80::893/64
Peer=fe80::1534/64
