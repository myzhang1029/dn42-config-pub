# vi: ft=systemd
# /etc/systemd/network/30-dn42-badaimweeb-us-lax1.network

[Match]
Name=wg3797bawuslax1

[Link]
RequiredForOnline=degraded:routable
RequiredFamilyForOnline=ipv6
Group=4242

[Network]
Description=WireGuard tunnel to AS4242423797 BadAimWeeb us-lax1
DHCP=no
IPv6AcceptRA=false
IPv4ReversePathFilter=no
IPv4Forwarding=yes
IPv6Forwarding=yes
KeepConfiguration=yes

[Address]
Address=fe80::893/64
Peer=fe80::3797/64
