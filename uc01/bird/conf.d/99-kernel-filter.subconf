filter kernel_import4 {
    if net ~ dn42_netset4 then accept;
    reject;
}

filter kernel_import6 {
    if net ~ dn42_netset6 then accept;
    reject;
}

filter kernel_export4 {
    if source = RTS_STATIC then reject;
    # DN42 BGP routes use table 4242
    # Internet BGP routes use table 211585
    if source = RTS_BGP then reject;
    # AMPR should be handled via policy routing on table 44
    if net ~ ampr_valid_netset then reject;
    accept;
}

filter kernel_export6 {
    if source = RTS_STATIC then reject;
    # DN42 BGP routes use table 4242
    # Internet BGP routes use table 211585
    if source = RTS_BGP then reject;
    accept;
}
