# vi: ft=systemd
# /etc/systemd/network/20-internal1-wg.network

[Match]
Name=wginternal1

[Link]
RequiredForOnline=degraded:routable
RequiredFamilyForOnline=ipv6
Group=4040
MTUBytes=1440

[Network]
Description=Internal WireGuard tunnel between be05 and ca04
DHCP=no
IPv6AcceptRA=false
IPv4ReversePathFilter=no
IPv4Forwarding=yes
IPv6Forwarding=yes
KeepConfiguration=yes

[Address]
Address=fe80::ca04/64

[Address]
Address=44.30.70.1/32
